{
  "name": "para-vault-mcp",
  "version": "0.1.0",
  "description": "MCP server exposing a PARA-method Obsidian vault as structured tools.",
  "type": "module",
  "bin": { "para-vault-mcp": "dist/index.js" },
  "main": "dist/index.js",
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "engines": { "node": ">=20" },
  "packageManager": "pnpm@11.0.0",
  "license": "MIT",
  "author": "Robert Tucker <robertwtucker@gmail.com>",
  "homepage": "https://github.com/robertwtucker/para-vault-mcp",
  "repository": { "type": "git", "url": "git+https://github.com/robertwtucker/para-vault-mcp.git" },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "date-fns": "^3.6.0",
    "globby": "^14.0.2",
    "gray-matter": "^4.0.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
