{
  "name": "@robertwtucker/para-vault-mcp",
  "version": "0.4.0",
  "description": "MCP server exposing a PARA-method Obsidian vault as structured tools.",
  "type": "module",
  "bin": {
    "para-vault-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "prebuild": "pnpm run clean",
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "overrides": {
      "hono": "^4.12.25",
      "qs": "^6.15.2",
      "vite": "^7.3.5"
    }
  },
  "license": "MIT",
  "author": "Robert Tucker <robertwtucker@gmail.com>",
  "homepage": "https://github.com/robertwtucker/para-vault-mcp",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/robertwtucker/para-vault-mcp.git"
  },
  "dependencies": {
    "@11ty/gray-matter": "^2.1.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "date-fns": "^3.6.0",
    "globby": "^14.0.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.9"
  }
}
